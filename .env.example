# ── Database (Neon PostgreSQL) ──────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/devdigest?sslmode=require"

# ── Redis (Upstash / BullMQ transport) ──────────────────
REDIS_HOST="your-upstash-redis.upstash.io"
REDIS_PORT=6379
REDIS_PASSWORD="your-redis-password"
REDIS_TLS=true

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghijk"
# TELEGRAM_WEBHOOK_URL="https://your-domain.com"    # Optional: uses polling mode if not set
# NGROK_AUTHTOKEN="your-ngrok-authtoken"            # Optional: auto-creates ngrok tunnel in dev

# ── API Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Digest Scheduling ────────────────────────────────────
DIGEST_CRON="0 8 * * *"              # Daily at 08:00 UTC
DIGEST_MAX_ARTICLES=10
